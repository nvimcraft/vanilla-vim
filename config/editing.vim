vim9script

# Indentation
set tabstop=4
set shiftwidth=4
set expandtab
set autoindent
set softtabstop=4

# Line wrapping
set wrap
set linebreak
set textwidth=0

# Backspace behavior
set backspace=indent,eol,start

# Completion
set completeopt=menuone,noinsert,noselect

# Format options
set formatoptions=tcqro
